# OSHXONA - Environment Variables (Example)
# Bu faylni .env ga nomini o'zgartirib oching

# Backend sozlamasi
NODE_ENV=development
BACKEND_PORT=3000
BACKEND_HOST=localhost

# Frontend sozlamasi
FRONTEND_PORT=5173
FRONTEND_HOST=localhost

# API sozlamasi
API_URL=http://localhost:3000

# Socket.io sozlamasi
SOCKET_IO_CORS=*
SOCKET_IO_PATH=/socket.io

# Demo sozlamasi
MAX_ORDERS=1000
ORDER_TIMEOUT=3600000
